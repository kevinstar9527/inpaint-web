{
  "name": "inpaint-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@heroicons/vue": "^2.1.5",
    "@inlang/paraglide-js-adapter-vite": "^1.0.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vueuse/core": "^10.9.0",
    "localforage": "^1.10.0",
    "opencv-ts": "^1.3.6",
    "vite": "^5.2.0",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-svgr": "^4.2.0",
    "vite-tsconfig-paths": "^4.2.1",
    "vue": "^3.4.21"
  },
  "scripts": {
    "start": "vite --host",
    "fast-build": "vite build",
    "build": "vue-tsc && vite build",
    "serve": "vite preview",
    "prepare": "husky install",
    "format": "prettier --write .",
    "postinstall": "paraglide-js compile --project ./project.inlang",
    "paraglide": "paraglide-js compile --project ./project.inlang",
    "deploy": "vite build && gh-pages -d dist"
  },
  "lint-staged": {
    "*.{vue,js,ts,jsx,tsx,css,sass,scss,md}": [
      "prettier --write",
      "echo '统一格式化完成🌸'"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@inlang/paraglide-js": "1.0.0-prerelease.19",
    "@testing-library/jest-dom": "^5.14.1",
    "@testing-library/user-event": "^13.5.0",
    "@testing-library/vue": "^8.0.1",
    "@types/jest": "^27.0.2",
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^5.1.0",
    "@vitest/coverage-v8": "^0.34.6",
    "@vue/test-utils": "^2.4.5",
    "autoprefixer": "^10.4.16",
    "cross-env": "7.x",
    "delay-cli": "^1.1.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-vue": "^9.24.0",
    "gh-pages": "^6.3.0",
    "husky": "^8.0.3",
    "jsdom": "^22.1.0",
    "lint-staged": "^15.1.0",
    "npm-run-all": "4.x",
    "postcss": "^8.4.31",
    "postcss-cli": "8.x",
    "postcss-preset-env": "6.x",
    "prettier": "^2.4.1",
    "tailwind-scrollbar": "^2.0.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.0.0",
    "vitest": "^0.34.6",
    "vue-tsc": "^2.0.6"
  }
}
